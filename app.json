{
  "expo": {
    "name": "onMangeQuoi",
    "slug": "onmangequoi",
    "version": "1.0.0",
    "scheme": "onmangequoi",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.famille.onmangequoi"
    },
    "android": {
      "package": "com.famille.onmangequoi",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Accès photos pour les plats"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7112aa3-ef18-4ab3-bfb2-6511b1583038"
      }
    }
  }
}
